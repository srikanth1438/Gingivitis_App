{
  "name": "gingivitis-selenium-tests",
  "version": "1.0.0",
  "description": "Selenium Web E2E Tests - Gingivitis Detection App",
  "scripts": {
    "test": "mocha web_e2e_tests.js --timeout 60000 --reporter spec",
    "test:html": "mocha web_e2e_tests.js --timeout 30000 --reporter mochawesome --reporter-options reportDir=../reports,reportFilename=Web_E2E_Report"
  },
  "dependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "selenium-webdriver": "^4.15.0"
  },
  "devDependencies": {
    "chromedriver": "^149.0.2"
  }
}